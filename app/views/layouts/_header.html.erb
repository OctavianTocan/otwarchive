<noscript><p id="javascript-warning"><%= t(".javascript") %></p></noscript>

<!-- BEGIN header -->
<% if @collection %>
  <!-- custom css for header -->
  <style type="text/css">
  #header h2 { 
    background: #616C90 <% if (header_url = @collection.header_image_url || (@collection_parent && @collection_parent.header_image_url)) %>
      <% height = (size = FastImage.size(header_url, timeout: 1)) ? "#{size[1]}px" : "100%" %>
      url(<%= header_url %>); height: <%= height %>
    <% end %>;
  }
  </style>
<% end %>

<header id="header" class="region<% if @collection %> collection<% end %>">

  <h1 class="heading">
    <%= link_to(image_tag("/images/ao3_logos/logo_42.png", alt: ArchiveConfig.ALT_LOGO, class: "logo", skip_pipeline: true) +
    content_tag(:span, ArchiveConfig.APP_NAME, class: "wordmark"), root_path) %>
    <button type="button" class="sidebar-toggle" aria-label="Toggle sidebar"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg></button>
  </h1>

  <% if logged_in? || logged_in_as_admin? %>
    <%= render "users/sessions/greeting" %>
  <% else %>
    <div id="login" class="dropdown">
      <p class="user actions">
        <%= link_to(raw('<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><path d="m10 17 5-5-5-5"/><path d="M15 12H3"/></svg>') + content_tag(:span, t(".login")), new_user_session_path(return_to: request.fullpath.start_with?(new_user_session_path) ? params[:return_to] : request.fullpath), id: "login-dropdown") %>
      </p>
      <%= render "users/sessions/login" %>
    </div>
  <% end %>

  <nav aria-label="<%= t(".nav.label") %>">
    <ul class="primary navigation actions">
      <li>
        <%= link_to(raw('<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 10.5 9-7 9 7"/><path d="M5 9v11h5v-6h4v6h5V9"/></svg>') + content_tag(:span, t(".nav.home", default: "Home")), root_path) %>
      </li>
      <li class="dropdown">
        <%= link_to(raw('<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v13"/><path d="M3 5.5A1.5 1.5 0 0 1 4.5 4H11v14H4.5A1.5 1.5 0 0 1 3 16.5z"/><path d="M21 5.5A1.5 1.5 0 0 0 19.5 4H13v14h6.5a1.5 1.5 0 0 0 1.5-1.5z"/></svg>') + content_tag(:span, t(".nav.fandoms")), menu_fandoms_path) %>
        <%= render "menu/menu_fandoms" %>
      </li>
      <li class="dropdown">
        <%= link_to(raw('<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>') + content_tag(:span, t(".nav.search")), menu_search_path) %>
        <%= render "menu/menu_search" %>
      </li>
      <li class="dropdown">
        <%= link_to(raw('<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>') + content_tag(:span, t(".nav.about")), menu_about_path) %>
        <%= render "menu/menu_about" %>
      </li>
    </ul>
  </nav>

  <% if logged_in_as_admin? %>
    <%= render "admin/header" %>
  <% end %>

  <% if @collection %>
    <h2 class="collections">
      <% unless @collection.header_image_url.present? %>
        <%= @collection.title || @collection_parent&.title || t(".collections.new") %>
      <% end %>
    </h2>
  <% end %>

  <div class="clear"></div>
  <div class="sidebar-resize" aria-hidden="true"></div>

</header>

<script>
(function(){
  var body=document.body, root=document.documentElement;
  var KC='ao3_sidebar_collapsed', KW='ao3_sidebar_w';
  try{ if(localStorage.getItem(KC)==='1') body.classList.add('sidebar-collapsed');
       var w=localStorage.getItem(KW); if(w) root.style.setProperty('--ao3-sidebar-w', w); }catch(e){}
  var t=document.querySelector('#header .sidebar-toggle');
  if(t) t.addEventListener('click', function(){
    var c=body.classList.toggle('sidebar-collapsed');
    try{ localStorage.setItem(KC, c?'1':'0'); }catch(e){}
  });
  var h=document.querySelector('#header .sidebar-resize');
  if(h) h.addEventListener('mousedown', function(e){
    if(body.classList.contains('sidebar-collapsed')) return;
    e.preventDefault(); body.classList.add('sidebar-resizing');
    function mv(ev){ var rem=Math.min(28, Math.max(13, ev.clientX/16)); root.style.setProperty('--ao3-sidebar-w', rem+'rem'); }
    function up(){ document.removeEventListener('mousemove',mv); document.removeEventListener('mouseup',up);
      body.classList.remove('sidebar-resizing');
      try{ localStorage.setItem(KW, getComputedStyle(root).getPropertyValue('--ao3-sidebar-w').trim()); }catch(e){}
    }
    document.addEventListener('mousemove',mv); document.addEventListener('mouseup',up);
  });
})();
</script>

<%= render "layouts/banner" %>

<!-- END header -->
